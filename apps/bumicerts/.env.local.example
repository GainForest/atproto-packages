# Bumicerts local environment — copy to .env.local and fill in.
# Do not commit .env.local.

# ─── Sentry (optional) ─────────────────────────────────────────────────────
# Error + performance monitoring. Leave unset locally — the SDK no-ops without
# a DSN. Get values from https://sentry.io > Project > Settings > Client Keys.
#
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
#
# Build-time only (production deploys, for source-map upload):
# SENTRY_AUTH_TOKEN=<sentry auth token with project:releases scope>
# SENTRY_ORG=<sentry org slug>
# SENTRY_PROJECT=<sentry project slug>

# ─── Everything else ───────────────────────────────────────────────────────
# Request the rest of the required server env vars from the team:
#   ATPROTO_JWK_PRIVATE, COOKIE_SECRET,
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_KEY,
#   AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_S3_BUCKET (AWS_REGION optional),
#   RESEND_API_KEY,
#   RATE_LIMIT_HMAC_KEY (>= 32 chars).
#
# Optional: DEBUG, GEMINI_API_KEY, BRANDFETCH_API_KEY,
#           FACILITATOR_HANDLE, FACILITATOR_PASSWORD, FACILITATOR_PRIVATE_KEY,
#           PRODUCTION_URL, STAGING_URL, PRODUCTION_BRANCH_NAME,
#           STAGING_BRANCH_NAME, BASE_RPC_URL.
#
# See apps/bumicerts/lib/env/server.ts for the full schema and validation rules.
