#!/bin/sh

STAGED=$(git diff --cached --name-only)

run_indexer=false
run_packages=false

echo "$STAGED" | grep -q '^apps/indexer/'   && run_indexer=true
echo "$STAGED" | grep -q '^packages/'       && run_packages=true

# If a shared package changes, also check indexer
if $run_packages; then
  run_indexer=true
fi

if $run_packages; then
  echo "⚡ Typechecking packages..."
  bun run --cwd packages/internal-utils typecheck || exit 1
  bun run --cwd packages/atproto-mutations-core typecheck || exit 1
  bun run --cwd packages/atproto-auth-next typecheck || exit 1
  bun run --cwd packages/atproto-mutations-next typecheck || exit 1
  bun run --cwd packages/leaflet-react typecheck || exit 1
fi

if $run_indexer; then
  echo "⚡ Typechecking indexer..."
  bun run indexer:typecheck || exit 1
fi
