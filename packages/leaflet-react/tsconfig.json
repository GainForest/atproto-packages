{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@gainforest/generated": ["../GENERATED/types/index.ts"],
      "@gainforest/generated/*": ["../GENERATED/types/*.ts"]
    },
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types"
    ]
  },
  "include": ["src/**/*"]
}
