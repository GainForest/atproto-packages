# Copy this file to tests/.env.test-credentials and fill in your values.
# .env.test-credentials is gitignored — never commit real credentials.
#
# Use an app password, not your main account password.
# bsky.social: Settings → Privacy and security → App passwords

ATPROTO_SERVICE=bsky.social
ATPROTO_IDENTIFIER=your-handle.bsky.social
ATPROTO_PASSWORD=your-app-password
